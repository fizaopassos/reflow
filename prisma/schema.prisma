generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USUÁRIOS ──────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  senha          String
  nome           String
  role           Role     @default(LEITOR)
  is_admin_local Boolean  @default(false)
  ativo          Boolean  @default(true)
  criado_em      DateTime @default(now())
  atualizado_em  DateTime @updatedAt

  leituras_criadas  Leitura[] @relation("leituras_criadas")
  leituras_editadas Leitura[] @relation("leituras_editadas")
  gestorCondominios CondominioGestor[]
  leitorCondominios CondominioLeitor[]

  @@map("users")
}

enum Role {
  ADMIN
  GESTOR
  LEITOR
}

// ── CONDOMÍNIOS ───────────────────────────────────────────────

model Condominio {
  id            String   @id @default(uuid())
  nome          String
  endereco      String?
  cidade        String?
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  unidades  Unidade[]
  gestores  CondominioGestor[]
  leitores  CondominioLeitor[]

  @@map("condominios")
}

// Relacionamento gestor <-> condomínio (N:N)
model CondominioGestor {
  condominio_id String
  user_id       String
  criado_em     DateTime @default(now())

  condominio Condominio @relation(fields: [condominio_id], references: [id])
  user       User       @relation(fields: [user_id], references: [id])

  @@id([condominio_id, user_id])
  @@map("condominio_gestores")
}

// Relacionamento leitor <-> condomínio (N:N)
model CondominioLeitor {
  condominio_id String
  user_id       String
  criado_em     DateTime @default(now())

  condominio Condominio @relation(fields: [condominio_id], references: [id])
  user       User       @relation(fields: [user_id], references: [id])

  @@id([condominio_id, user_id])
  @@map("condominio_leitores")
}

// ── UNIDADES ──────────────────────────────────────────────────

model Unidade {
  id            String   @id @default(uuid())
  condominio_id String
  identificador String   // ex: "Apto 101", "Bloco A - 202"
  andar         String?
  bloco         String?
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  condominio Condominio @relation(fields: [condominio_id], references: [id])
  medidores  Medidor[]

  @@map("unidades")
}

// ── MEDIDORES ─────────────────────────────────────────────────

model Medidor {
  id            String      @id @default(uuid())
  unidade_id    String
  tipo          TipoMedidor @default(AGUA)
  numero_serie  String?
  localizacao   String?     // ex: "Corredor térreo", "Dentro do apto"
  ativo         Boolean     @default(true)
  criado_em     DateTime    @default(now())
  atualizado_em DateTime    @updatedAt

  unidade  Unidade   @relation(fields: [unidade_id], references: [id])
  leituras Leitura[]

  @@map("medidores")
}

enum TipoMedidor {
  AGUA
  ENERGIA
  GAS
}

// ── LEITURAS ──────────────────────────────────────────────────

model Leitura {
  id               String         @id @default(uuid())
  medidor_id       String
  user_id          String
  editado_por_id   String?
  valor            Decimal        @db.Decimal(10, 3)
  metodo           MetodoLeitura  @default(MANUAL)
  fonte            FonteLeitura   @default(APP)
  confianca        String?
  observacoes      String?
  foto_url         String?
  referencia_dia   Int
  referencia_mes   Int
  referencia_ano   Int
  criado_em        DateTime       @default(now())
  atualizado_em    DateTime       @updatedAt

  medidor     Medidor @relation(fields: [medidor_id], references: [id])
  user        User    @relation("leituras_criadas", fields: [user_id], references: [id])
  editado_por User?   @relation("leituras_editadas", fields: [editado_por_id], references: [id])

  @@unique([medidor_id, referencia_dia, referencia_mes, referencia_ano])
  @@index([medidor_id, referencia_mes, referencia_ano])
  @@map("leituras")
}

enum MetodoLeitura {
  GEMINI
  MANUAL
  AUTOMATICO
}

enum FonteLeitura {
  APP
  IOT
  INTEGRACAO
}
